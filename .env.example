# ===== TestCase Agent — LLM 配置 =====
# 复制此文件为 .env 并填入配置

# ---- 方式 A: OpenAI 兼容接口 ----
LLM_PROVIDER=openai
LLM_BASE_URL=https://your-api-gateway.com
LLM_MODEL=deepseek-v4-pro
OPENAI_API_KEY=sk-xxx

# ---- 方式 B: 通义千问 (DashScope) ----
# LLM_PROVIDER=dashscope
# LLM_MODEL=qwen-max
# DASHSCOPE_API_KEY=sk-xxx

# ---- 审查轮数 (可选，默认 3) ----
# LLM_MAX_ROUNDS=3
